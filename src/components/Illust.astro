---
import type { HeroIllust, IllustEntry } from '../data/types';
interface Props {
  hero: HeroIllust[];
  illustrations: Record<string, IllustEntry>;
}
const { hero, illustrations } = Astro.props;
---
<div class={`illust-row ${hero.length === 2 ? 'cols-2' : ''}`}>
  {hero.map((h) => {
    const entry = illustrations[h.type];
    return (
      <div class={`illust illust--${h.type}`}>
        {entry?.img && (
          <img
            class="illust__photo"
            src={entry.img}
            alt={entry.label ?? h.label}
            loading="lazy"
            decoding="async"
            referrerpolicy="no-referrer"
          />
        )}
        {entry?.icon && <span class="illust__icon">{entry.icon}</span>}
        <span class="illust__label">{h.label}</span>
      </div>
    );
  })}
</div>

<script>
  // 圖片載入失敗時隱藏 img，露出 CSS 漸層 fallback
  document.querySelectorAll<HTMLImageElement>('.illust__photo').forEach((img) => {
    img.addEventListener('error', () => {
      img.style.display = 'none';
    });
  });
</script>
