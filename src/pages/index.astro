---
import Layout from '../layouts/Layout.astro';
import { getAllTrips } from '../data/trips';

const base = import.meta.env.BASE_URL;
const b = base.endsWith('/') ? base.slice(0, -1) : base;
const trips = getAllTrips();
---

<Layout title="我的旅程 · Trip Planner" activeNav="trips-list">

  <section class="cover">
    <span class="cover__badge">MY TRIPS</span>
    <h1 class="cover__title">我的旅程</h1>
    <div class="cover__subtitle">私人旅遊行程規劃</div>
    <div class="cover__tagline">逐趟記錄、按日翻閱、行前自我檢查</div>
  </section>

  <section class="section">
    <h2 class="section-title">所有行程<small>ALL TRIPS · {trips.length}</small></h2>
    <div class="day-summary-grid">
      {trips.map((trip) => (
        <a class="day-summary" href={`${b}/trips/${trip.slug}`}>
          <div class="day-summary__num">
            {trip.meta.badge && <span style="font-size:11px; letter-spacing:0.08em; color:var(--c-text-soft);">{trip.meta.badge}</span>}
            <strong style="font-size:32px;">{trip.meta.totalDays}</strong>
            <em>天 {trip.meta.totalNights} 夜</em>
          </div>
          <div class="day-summary__body">
            <strong>{trip.meta.title}</strong>
            <span style="display:block; color:var(--c-text-soft); font-size:13px; margin-bottom:6px;">
              {trip.meta.subtitle} · {trip.meta.dateRange}
            </span>
            {trip.meta.tagline ?? trip.meta.description}
          </div>
        </a>
      ))}
    </div>
  </section>

</Layout>
