---
import Layout from '../../../../layouts/Layout.astro';
import DayHero from '../../../../components/DayHero.astro';
import Illust from '../../../../components/Illust.astro';
import Timeline from '../../../../components/Timeline.astro';
import ShopBlock from '../../../../components/ShopBlock.astro';
import TransitCard from '../../../../components/TransitCard.astro';
import InfoCard from '../../../../components/InfoCard.astro';
import MealTable from '../../../../components/MealTable.astro';
import Tip from '../../../../components/Tip.astro';
import { getAllTrips } from '../../../../data/trips';

export async function getStaticPaths() {
  return getAllTrips().flatMap((trip) =>
    trip.days.map((day) => ({
      params: { slug: trip.slug, num: String(day.num) },
      props: { trip, day },
    })),
  );
}

const { trip, day } = Astro.props;
const base = import.meta.env.BASE_URL;
const b = base.endsWith('/') ? base.slice(0, -1) : base;
const prev = day.num > 1 ? day.num - 1 : null;
const next = day.num < trip.days.length ? day.num + 1 : null;
const tripBase = `${b}/trips/${trip.slug}`;
---

<Layout title={`Day ${day.num} · ${day.title} · ${trip.meta.title}`} activeNav={`day-${day.num}`} trip={trip}>
  <DayHero day={day} />

  {day.hero.length > 0 && <Illust hero={day.hero} illustrations={trip.illustrations} />}

  <h2 class="section-title" style="font-size: 18px; margin-top: 32px;">行程時間軸</h2>
  <Timeline items={day.timeline} />

  {day.table && <MealTable table={day.table} />}

  {day.shops?.map((block) => <ShopBlock block={block} />)}

  {day.transit?.map((card) => <TransitCard card={card} />)}

  {day.infos?.map((card) => <InfoCard card={card} />)}

  {day.tip && <Tip text={day.tip} />}

  <nav style="display:flex; justify-content:space-between; gap:12px; margin-top:48px; padding-top:24px; border-top:1px solid var(--c-line);">
    {prev ? (
      <a href={`${tripBase}/days/${prev}`} style="font-size:14px; color:var(--c-text-soft);">← Day {prev}</a>
    ) : (
      <a href={tripBase} style="font-size:14px; color:var(--c-text-soft);">← 回總覽</a>
    )}
    {next ? (
      <a href={`${tripBase}/days/${next}`} style="font-size:14px; color:var(--c-text-soft);">Day {next} →</a>
    ) : (
      <a href={`${tripBase}/checklist`} style="font-size:14px; color:var(--c-text-soft);">前往 Checklist →</a>
    )}
  </nav>
</Layout>
