---
import type { TimelineItem } from '../data/types';
import MapLink from './MapLink.astro';
import ShopBlock from './ShopBlock.astro';
import MealTable from './MealTable.astro';
import RouteFlow from './RouteFlow.astro';
interface Props { items: TimelineItem[]; }
const { items } = Astro.props;
---
<div class="timeline">
  {items.map((item) => (
    <div class="timeline-item">
      <div class="timeline-item__time">{item.time}</div>
      <div class="timeline-item__place">
        {item.mapQuery && <MapLink query={item.mapQuery} label={item.place} />}
        <span>{item.place}</span>
      </div>
      <div class="timeline-item__desc">{item.desc}</div>
      {item.route && <RouteFlow steps={item.route} />}
      {item.alt?.map((a) => (
        <div class="timeline-alt">
          <strong>
            {a.mapQuery && <MapLink query={a.mapQuery} label={a.title} />}
            <span>{a.title}</span>
          </strong>
          <span>{a.body}</span>
        </div>
      ))}
      {item.table && <MealTable table={item.table} />}
      {item.shops?.map((block) => <ShopBlock block={block} />)}
    </div>
  ))}
</div>
