---
import type { MealTable } from '../data/types';
import MapLink from './MapLink.astro';
interface Props { table: MealTable; }
const { table } = Astro.props;
---
<table class="meal-table">
  <caption style="text-align:left; font-size:14px; color:var(--c-text-muted); padding:8px 0;">
    {table.caption}
  </caption>
  <thead>
    <tr>
      <th>Plan</th>
      <th>店名</th>
      <th>特色</th>
    </tr>
  </thead>
  <tbody>
    {table.rows.map((r) => (
      <tr>
        <td class="plan">{r.plan}</td>
        <td>
          <span class="cell-with-map">
            {r.name}
            {r.mapQuery && <MapLink query={r.mapQuery} label={r.name} />}
          </span>
        </td>
        <td>{r.feature}</td>
      </tr>
    ))}
  </tbody>
</table>
