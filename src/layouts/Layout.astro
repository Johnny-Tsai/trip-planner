---
import '../styles/global.css';
import type { Trip } from '../data/types';

interface Props {
  title: string;
  description?: string;
  activeNav?: string;
  trip?: Trip;
}

const PLATFORM_NAME = 'Trip Planner';
const PLATFORM_DESC = '私人旅遊行程平台';
const PLATFORM_THEME = '#c44834';

const { title, description, activeNav, trip } = Astro.props;
const base = import.meta.env.BASE_URL;
const b = base.endsWith('/') ? base.slice(0, -1) : base;

const themeColor = trip?.meta.themeColor ?? PLATFORM_THEME;
const metaDesc = description ?? trip?.meta.description ?? PLATFORM_DESC;

const brandHref = trip ? `${b}/trips/${trip.slug}` : `${b}/`;
const brandTitle = trip?.meta.title ?? PLATFORM_NAME;
const brandSub = trip?.meta.subtitle ?? '';

// 有 trip：顯示該趟內部導覽；沒 trip（trips 清單頁）：只顯示「回首頁」
const nav = trip
  ? [
      { id: 'home', label: '總覽', href: `${b}/trips/${trip.slug}` },
      { id: 'transit', label: '交通指南', href: `${b}/trips/${trip.slug}/transit` },
      ...trip.days.map((d) => ({
        id: `day-${d.num}`,
        label: `Day ${d.num}`,
        href: `${b}/trips/${trip.slug}/days/${d.num}`,
      })),
      { id: 'checklist', label: 'Checklist', href: `${b}/trips/${trip.slug}/checklist` },
    ]
  : [{ id: 'trips-list', label: '所有旅程', href: `${b}/` }];

const footerLine = trip
  ? `© ${trip.meta.dates.start.split('/')[0]} ${trip.meta.title} · Built with Astro · Hosted on GitHub Pages`
  : `© ${new Date().getFullYear()} ${PLATFORM_NAME} · Built with Astro · Hosted on GitHub Pages`;
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={metaDesc} />
    <meta name="theme-color" content={themeColor} />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700&family=Noto+Serif+TC:wght@600;700&display=swap"
      rel="stylesheet"
    />
    {trip?.meta.themeColor && (
      <style set:html={`:root { --c-accent: ${trip.meta.themeColor}; }`}></style>
    )}
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__inner">
        <a class="site-header__brand" href={brandHref}>
          {brandTitle} {brandSub && <small>{brandSub}</small>}
        </a>
        <nav class="site-header__nav" aria-label="主要導覽">
          {nav.map((item) => (
            <a href={item.href} class={activeNav === item.id ? 'is-active' : ''}>
              {item.label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <p>{footerLine}</p>
      <p>內容僅供參考，店家資訊與票價請以實際為準</p>
    </footer>
  </body>
</html>
