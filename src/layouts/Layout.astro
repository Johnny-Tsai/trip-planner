---
import '../styles/global.css';
import type { Trip } from '../data/types';
import { getAllTrips } from '../data/trips';

interface Props {
  title: string;
  description?: string;
  activeNav?: string;
  trip?: Trip;
}

const PLATFORM_NAME = 'Trip Planner';
const PLATFORM_DESC = '私人旅遊行程平台';
const PLATFORM_THEME = '#c44834';

const { title, description, activeNav, trip } = Astro.props;
const base = import.meta.env.BASE_URL;
const b = base.endsWith('/') ? base.slice(0, -1) : base;

const allTrips = getAllTrips();

const themeColor = trip?.meta.themeColor ?? PLATFORM_THEME;
const metaDesc = description ?? trip?.meta.description ?? PLATFORM_DESC;
const currentYear = new Date().getFullYear();
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={metaDesc} />
    <meta name="theme-color" content={themeColor} />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700&family=Noto+Serif+TC:wght@600;700&display=swap"
      rel="stylesheet"
    />
    {trip?.meta.themeColor && (
      <style set:html={`:root { --c-accent: ${trip.meta.themeColor}; }`}></style>
    )}
  </head>
  <body>
    <header class="mobile-header">
      <button
        type="button"
        class="hamburger"
        aria-label="開啟導覽"
        data-action="open-sidebar"
      >
        <span></span><span></span><span></span>
      </button>
      <a class="mobile-header__brand" href={b || '/'}>{PLATFORM_NAME}</a>
    </header>

    <div class="layout">
      <button
        type="button"
        class="sidebar-expand"
        aria-label="展開側邊導覽"
        data-action="expand-sidebar"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
          <line x1="4" y1="7" x2="20" y2="7"/>
          <line x1="4" y1="12" x2="20" y2="12"/>
          <line x1="4" y1="17" x2="20" y2="17"/>
        </svg>
      </button>

      <aside class="sidebar" aria-label="主要導覽">
        <button
          type="button"
          class="sidebar__toggle"
          aria-label="收合或關閉導覽"
          data-action="toggle-sidebar"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="14 6 8 12 14 18"/>
          </svg>
        </button>

        <a class="sidebar__brand" href={b || '/'}>
          {PLATFORM_NAME}
          <small>{PLATFORM_DESC}</small>
        </a>

        <nav class="sidebar__nav">
          <div class="sidebar__section">
            <h4 class="sidebar__heading">所有旅程</h4>
            {allTrips.map((t) => (
              <a
                href={`${b}/trips/${t.slug}`}
                class={trip?.slug === t.slug ? 'is-active' : ''}
                style={`--trip-color: ${t.meta.themeColor ?? PLATFORM_THEME}`}
              >
                <span class="sidebar__dot"></span>
                {t.meta.title}
              </a>
            ))}
          </div>

        </nav>

        <footer class="sidebar__footer">
          <p>© {currentYear} {PLATFORM_NAME}</p>
          <p>Built with Astro · Hosted on GitHub Pages</p>
        </footer>
      </aside>

      <div class="nav-backdrop" aria-hidden="true"></div>

      <div class="layout__main">
        <slot name="hero" />
        {trip && (
          <nav
            class="trip-tabs"
            aria-label="行程子頁切換"
            style={`--trip-color: ${trip.meta.themeColor ?? PLATFORM_THEME}`}
          >
            <a
              href={`${b}/trips/${trip.slug}`}
              class={activeNav === 'home' ? 'is-active' : ''}
            >總覽</a>
            <a
              href={`${b}/trips/${trip.slug}/transit`}
              class={activeNav === 'transit' ? 'is-active' : ''}
            >交通</a>
            {trip.days.map((d) => (
              <a
                href={`${b}/trips/${trip.slug}/days/${d.num}`}
                class={activeNav === `day-${d.num}` ? 'is-active' : ''}
              >Day {d.num}</a>
            ))}
          </nav>
        )}
        <main>
          <slot />
        </main>
        <footer class="site-footer">
          <p>內容僅供參考，店家資訊與票價請以實際為準</p>
        </footer>
      </div>
    </div>

    <script>
      const sidebar = document.querySelector<HTMLElement>('.sidebar');
      const layout = document.querySelector<HTMLElement>('.layout');
      const backdrop = document.querySelector<HTMLElement>('.nav-backdrop');
      const isMobile = () => window.matchMedia('(max-width: 879px)').matches;

      const openMobile = () => {
        sidebar?.classList.add('is-open');
        backdrop?.classList.add('is-active');
      };
      const closeMobile = () => {
        sidebar?.classList.remove('is-open');
        backdrop?.classList.remove('is-active');
      };
      const toggleDesktop = () => {
        layout?.classList.toggle('is-collapsed');
      };

      document.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;

        if (target.closest('[data-action="open-sidebar"]')) {
          openMobile();
          return;
        }
        if (target.closest('[data-action="toggle-sidebar"]')) {
          if (isMobile()) closeMobile();
          else toggleDesktop();
          return;
        }
        if (target.closest('[data-action="expand-sidebar"]')) {
          layout?.classList.remove('is-collapsed');
          return;
        }
        // 手機：點 backdrop 或 sidebar 內連結 → 自動關閉
        if (isMobile()) {
          if (target.closest('.nav-backdrop') || target.closest('.sidebar a')) {
            closeMobile();
          }
        }
      });

      // ESC 鍵關閉手機抽屜
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && isMobile() && sidebar?.classList.contains('is-open')) {
          closeMobile();
        }
      });

      // 視窗從手機 resize 回桌機時，清除手機 open 狀態（避免狀態錯亂）
      window.addEventListener('resize', () => {
        if (!isMobile()) closeMobile();
      });

      // 頁面載入後，把當前 active 的 trip-tab 水平置中於 trip-tabs 滾動列
      requestAnimationFrame(() => {
        const activeTab = document.querySelector<HTMLElement>('.trip-tabs a.is-active');
        if (activeTab) {
          activeTab.scrollIntoView({ block: 'nearest', inline: 'center' });
        }
      });
    </script>
  </body>
</html>
